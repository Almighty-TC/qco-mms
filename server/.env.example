# ─── QMAT BACKEND ENV TEMPLATE ───────────────────────────────
# Copy to server/.env and fill in real values locally; on Azure App
# Service set these as Application Settings (never commit real secrets).

# ─── DATABASE (Azure MySQL, SSL required) ────────────────────
DB_HOST=your-db-host.mysql.database.azure.com
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=qmat

# ─── AUTH ────────────────────────────────────────────────────
# JWT_SECRET MUST be set in production (a long random string). If unset,
# the code falls back to an insecure dev default — never rely on that in prod.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h

# ─── SERVER ──────────────────────────────────────────────────
# App Service injects PORT automatically; locally defaults to 3001.
PORT=3001

# ─── SMTP (Microsoft 365) ────────────────────────────────────
# Email no-ops until SMTP_PASS is set to a real value (not the placeholder).
# Required before external onboarding / password-reset delivery works.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-password-here
SMTP_FROM=QCO Group MMS <your-smtp-user@example.com>

# ─── ALERTS ──────────────────────────────────────────────────
# Comma-separated extra recipients for system alert emails (optional).
ADDITIONAL_ALERT_EMAILS=
