# ─── FRONTEND (Vite) ─────────────────────────────────────────
# Base URL of the QMAT backend API. Read at BUILD time by Vite and
# inlined into the bundle (import.meta.env.VITE_API_URL), so it must
# be set when the frontend is built/deployed — not at runtime.
#   - Local dev:  http://localhost:3001  (also the in-code default)
#   - Deployed:   https://<your-app-service-name>.azurewebsites.net
VITE_API_URL=http://localhost:3001
