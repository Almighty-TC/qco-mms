# ─── DEPENDENCIES ───────────────────────────────────────────
node_modules/

# ─── ENVIRONMENT VARIABLES ──────────────────────────────────
# Never commit secrets — copy .env.example and fill in locally
.env
.env.local
.env.*.local
# one-off admin DB creds for migrations — local only, never committed
.env.admin
**/.env.admin

# ─── BUILD OUTPUT ───────────────────────────────────────────
dist/
dist-ssr/
build/
# backend deploy zip — regenerated each deploy (DEPLOY_AZURE.md step 2e)
qmat-backend.zip

# ─── STRAY / LOCAL DOCS ─────────────────────────────────────
QCO MMS.docx

# ─── LOGS ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS FILES ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── EDITOR / IDE ───────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── VITE / TYPESCRIPT CACHE ────────────────────────────────
*.tsbuildinfo
.vite/

# ─── PROJECT-LOCAL ──────────────────────────────────────────
# Claude Code session memory — local only, not for version control
.claude/

# Catch nested .env files (e.g. server/.env)
**/.env

# Runtime-uploaded files (owned by modules, not source)
server/uploads/

# Local doc backups (kept out of version history)
docs/_backup_*/
